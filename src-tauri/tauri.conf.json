{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Just Transcribe This",
  "version": "0.1.1",
  "identifier": "com.justtranscribethis.desktop",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:5001"
  },
  "app": {
    "windows": [
      {
        "title": "Just Transcribe This",
        "width": 720,
        "height": 960,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/backend"
    ]
  }
}
